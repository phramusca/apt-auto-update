#!/bin/bash
set -euo pipefail

CRON_FILE="/etc/cron.d/apt-auto-update"
RUNNER="/usr/lib/apt-auto-update/run-maintenance.sh"
MARKER="managed-by-apt-auto-update"

die() { echo "apt-auto-update: $*" >&2; exit 1; }

require_root() {
  [[ $EUID -eq 0 ]] || exec sudo "$0" "$@"
}

usage() {
  cat <<'EOF'
Usage: apt-auto-update <command> [options]

  run                 Run now: apt update, upgrade, autoremove, autoclean, clean
  enable [--hour N]   Enable daily run at hour N (0–23), default: 4
  disable             Disable scheduled task (remove cron fragment)
  status              Show whether automatic updates are enabled

With no command: same as status.
EOF
}

cmd_run() {
  require_root run "$@"
  [[ -x "$RUNNER" ]] || die "internal script missing: $RUNNER"
  exec "$RUNNER"
}

cmd_enable() {
  require_root enable "$@"
  local hour=4
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --hour)
        [[ $# -ge 2 ]] || die "--hour requires a value"
        hour=$2
        shift 2
        ;;
      *) die "unknown option: $1 (see: apt-auto-update --help)" ;;
    esac
  done
  [[ "$hour" =~ ^[0-9]+$ ]] || die "invalid hour: $hour"
  (( hour >= 0 && hour <= 23 )) || die "hour out of range 0–23: $hour"

  umask 022
  cat >"$CRON_FILE" <<EOF
# $MARKER — do not edit by hand; use: apt-auto-update disable|enable
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
0 $hour * * * root test -x $RUNNER && $RUNNER >> /var/log/apt-auto-update.log 2>&1
EOF
  chmod 0644 "$CRON_FILE"
  echo "Automatic updates enabled: daily at ${hour}:00 (root), log: /var/log/apt-auto-update.log"
}

cmd_disable() {
  require_root disable "$@"
  if [[ -f "$CRON_FILE" ]]; then
    if grep -q "$MARKER" "$CRON_FILE" 2>/dev/null; then
      rm -f "$CRON_FILE"
      echo "Automatic updates disabled (cron file removed)."
    else
      die "refusing to remove $CRON_FILE (not generated by this package)"
    fi
  else
    echo "Already disabled (no $CRON_FILE)."
  fi
}

cmd_status() {
  if [[ -f "$CRON_FILE" ]] && grep -q "$MARKER" "$CRON_FILE" 2>/dev/null; then
    echo "Status: enabled"
    echo "File: $CRON_FILE"
    sed 's/^/  /' "$CRON_FILE"
  else
    echo "Status: disabled (no $MARKER task)"
  fi
}

main() {
  case "${1:-}" in
    ''|status) cmd_status ;;
    run) shift; cmd_run "$@" ;;
    enable) shift; cmd_enable "$@" ;;
    disable) shift; cmd_disable "$@" ;;
    -h|--help) usage ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
